# UFO Agent Configurations — omy-skills / pc-assistant 模板（火山引擎方舟 Doubao）
# 用法：复制为 agents.yaml 后填入 API Key，或运行 scripts/install-pc.ps1 -ApiKey "..."
# 全局 LLM 参数（MAX_TOKENS 等）见 system.yaml，勿在此重复。

HOST_AGENT:
  VISUAL_MODE: True
  REASONING_MODEL: False
  API_TYPE: "openai"  # OpenAI 兼容协议
  API_BASE: "https://ark.cn-beijing.volces.com/api/v3"
  API_KEY: "YOUR_VOLC_ARK_API_KEY"
  API_VERSION: "2025-02-01-preview"
  API_MODEL: "doubao-seed-2-1-turbo-260628"
  PROMPT: "ufo/prompts/share/base/host_agent.yaml"
  EXAMPLE_PROMPT: "ufo/prompts/examples/{mode}/host_agent_example.yaml"

APP_AGENT:
  VISUAL_MODE: True
  REASONING_MODEL: False
  API_TYPE: "openai"
  API_BASE: "https://ark.cn-beijing.volces.com/api/v3"
  API_KEY: "YOUR_VOLC_ARK_API_KEY"
  API_VERSION: "2025-02-01-preview"
  API_MODEL: "doubao-seed-2-1-turbo-260628"
  PROMPT: "ufo/prompts/share/base/app_agent.yaml"
  EXAMPLE_PROMPT: "ufo/prompts/examples/{mode}/app_agent_example.yaml"
  EXAMPLE_PROMPT_AS: "ufo/prompts/examples/{mode}/app_agent_example_as.yaml"

BACKUP_AGENT:
  VISUAL_MODE: True
  API_TYPE: "openai"
  API_BASE: "https://ark.cn-beijing.volces.com/api/v3"
  API_KEY: "YOUR_VOLC_ARK_API_KEY"
  API_VERSION: "2025-02-01-preview"
  API_MODEL: "doubao-seed-2-0-lite-260428"

EVALUATION_AGENT:
  VISUAL_MODE: True
  REASONING_MODEL: False
  API_TYPE: "openai"
  API_BASE: "https://ark.cn-beijing.volces.com/api/v3"
  API_KEY: "YOUR_VOLC_ARK_API_KEY"
  API_VERSION: "2025-02-01-preview"
  API_MODEL: "doubao-seed-2-1-turbo-260628"

# Omniparser（本仓库 system.yaml 默认仅用 uia，一般无需填写）
OMNIPARSER:
  ENDPOINT: "http://xxx.xxx.xxx.xxx:xxxx"
  BOX_THRESHOLD: 0.05
  IOU_THRESHOLD: 0.1
  USE_PADDLEOCR: True
  IMGSZ: 640

# App API Prompt Configuration
APP_API_PROMPT_ADDRESS:
  "WINWORD.EXE": "ufo/prompts/apps/word/api.yaml"
  "EXCEL.EXE": "ufo/prompts/apps/excel/api.yaml"
  "msedge.exe": "ufo/prompts/apps/web/api.yaml"
  "chrome.exe": "ufo/prompts/apps/web/api.yaml"
